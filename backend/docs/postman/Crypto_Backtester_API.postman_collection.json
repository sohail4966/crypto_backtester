    {
      "name": "02b Chart Data",
      "description": "Phase 4b unified chart window — candles + indicators in one response. Default limit 500 bars.",
      "item": [
        {
          "name": "Chart data (default limit)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/chart-data?symbolId={{symbol}}&timeframe={{timeframe}}&start={{from_ts}}&end={{to_ts}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "chart-data"],
              "query": [
                { "key": "symbolId", "value": "{{symbol}}" },
                { "key": "timeframe", "value": "{{timeframe}}" },
                { "key": "start", "value": "{{from_ts}}" },
                { "key": "end", "value": "{{to_ts}}" }
              ]
            }
          }
        },
        {
          "name": "Chart data (with RSI + EMA)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/chart-data?symbolId={{symbol}}&timeframe=1h&start={{from_ts}}&end={{to_ts}}&limit=200&indicators=%5B%7B%22key%22%3A%22RSI%22%2C%22params%22%3A%7B%22period%22%3A14%7D%7D%2C%7B%22key%22%3A%22EMA%22%2C%22params%22%3A%7B%22period%22%3A20%7D%7D%5D",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "chart-data"],
              "query": [
                { "key": "symbolId", "value": "{{symbol}}" },
                { "key": "timeframe", "value": "1h" },
                { "key": "start", "value": "{{from_ts}}" },
                { "key": "end", "value": "{{to_ts}}" },
                { "key": "limit", "value": "200" },
                {
                  "key": "indicators",
                  "value": "[{\"key\":\"RSI\",\"params\":{\"period\":14}},{\"key\":\"EMA\",\"params\":{\"period\":20}}]"
                }
              ]
            }
          }
        }
      ]
    },
