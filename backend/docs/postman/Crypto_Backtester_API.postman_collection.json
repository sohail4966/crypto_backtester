    {
      "name": "07 Replay (REST)",
      "item": [
        {
          "name": "Create replay session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const data = pm.response.json();",
                  "    pm.collectionVariables.set('session_id', data.session_id);",
                  "    console.log('session_id set to', data.session_id);",
                  "    console.log('Connect WebSocket:', data.ws_url);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"symbol\": \"{{symbol}}\",\n  \"timeframe\": \"{{timeframe}}\",\n  \"start\": {{from_ts}},\n  \"end\": {{to_ts}},\n  \"step_timeframe\": \"{{timeframe}}\",\n  \"speed\": 1.0,\n  \"autoplay\": false,\n  \"indicators\": [\n    {\"key\": \"RSI\", \"params\": {\"period\": 14}}\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/v1/replay/sessions"
          }
        },
        {
          "name": "Create replay session (15m steps on 1h chart)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('session_id', pm.response.json().session_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"symbol\": \"BTC/USDT\",\n  \"timeframe\": \"1h\",\n  \"start\": {{from_ts}},\n  \"step_timeframe\": \"15m\",\n  \"speed\": 2.0,\n  \"autoplay\": false,\n  \"indicators\": [\n    {\"key\": \"SMA\", \"params\": {\"period\": 20}}\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/v1/replay/sessions"
          }
        },
