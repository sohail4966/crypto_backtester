        },
        {
          "name": "Search symbols (alias)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/symbols/search?q=BTC&active_only=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "symbols", "search"],
