    {
      "name": "04 Indicators",
      "item": [
        {
          "name": "Indicator catalog",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/indicators"
          }
        },
        {
          "name": "Compute RSI + SMA",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"symbol\": \"{{symbol}}\",\n  \"timeframe\": \"{{timeframe}}\",\n  \"from\": {{from_ts}},\n  \"to\": {{to_ts}},\n  \"indicators\": [\n    {\"key\": \"RSI\", \"params\": {\"period\": 14}, \"pane\": \"subchart\"},\n    {\"key\": \"SMA\", \"params\": {\"period\": 20}, \"pane\": \"overlay\"}\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/v1/indicators/compute"
          }
        },
        {
          "name": "Compute MACD (multi-output)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"symbol\": \"{{symbol}}\",\n  \"timeframe\": \"{{timeframe}}\",\n  \"from\": {{from_ts}},\n  \"to\": {{to_ts}},\n  \"indicators\": [\n    {\"key\": \"MACD_LINE\", \"params\": {\"fast\": 12, \"slow\": 26, \"signal\": 9}},\n    {\"key\": \"MACD_SIGNAL\", \"params\": {\"fast\": 12, \"slow\": 26, \"signal\": 9}},\n    {\"key\": \"MACD_HIST\", \"params\": {\"fast\": 12, \"slow\": 26, \"signal\": 9}}\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/v1/indicators/compute"
          }
        }
      ]
