# Local Docker Compose (port 5433 avoids clashing with a local Postgres on 5432)
DATABASE_URL=postgresql://backtester:backtester@localhost:5433/backtester

# Or set POSTGRES_* parts (used by Render when DATABASE_URL is unset):
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5433
# POSTGRES_USER=backtester
# POSTGRES_PASSWORD=backtester
# POSTGRES_DB=backtester

# API (production: set CORS_ORIGINS to your Vercel URL)
# CORS_ORIGINS=https://your-app.vercel.app
